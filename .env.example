# Database — Coolify will provide this if using a managed Postgres service
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://orchard:yourpassword@localhost:5432/orchardops"

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-generated-secret"

# Your app URL — update when domain is live
NEXTAUTH_URL="https://ops.orchardtalent.com.au"

# Node environment
NODE_ENV="production"
